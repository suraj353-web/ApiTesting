pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Run Test') {
            steps {
                bat 'npx playwright test tests/ApiTesting.spec.ts'
            }
        }

        stage('Upload Report To S3') {
            steps {

                withCredentials([usernamePassword(
                    credentialsId: 'aws-s3',
                    usernameVariable: 'AWS_ACCESS_KEY_ID',
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )]) {

                    bat 'aws s3 sync playwright-report s3://playwright-apitest-reports-suraj/'
                }
            }
        }
    }
}
