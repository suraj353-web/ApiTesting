pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Run Test') {
            steps {
                bat 'npx playwright test tests/ApiTesting.spec.ts'
            }
        }

        stage('Upload Report To S3') {
            steps {

                withCredentials([usernamePassword(
                    credentialsId: 'aws-s3',
                    usernameVariable: 'AWS_ACCESS_KEY_ID',
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )]) {

                    bat 'aws s3 sync playwright-report s3://playwright-apitest-reports-suraj/'
                }
            }
        }
    }

    post {
        always {
            emailext(
                to: 'surajgcp353@gmail.com',
                subject: "Playwright Execution - ${currentBuild.currentResult}",
                body: """
Hello,

Playwright execution completed.

Job Name : ${env.JOB_NAME}
Build Number : ${env.BUILD_NUMBER}
Build Status : ${currentBuild.currentResult}

HTML Report:
https://playwright-apitest-reports-suraj.s3.amazonaws.com/index.html

Regards,
Jenkins
"""
            )
        }
    }
}
