pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Cloning repository'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Install Playwright Browsers') {
            steps {
                bat 'npx playwright install'
            }
        }

        stage('Run API Tests') {
            steps {
                bat 'npx playwright test tests/ApiTesting.spec.ts'
            }
        }

    }
}
